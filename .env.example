# Copy to .env and edit. Never commit .env.
#
# These are read by docker-compose.yml AND by Python (via python-dotenv).
# Keeping them in one place avoids password drift.

# ─── Postgres credentials (used by docker-compose AND Python client) ────────
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism
POSTGRES_DB=prism_rag

# Python uses this. Host = localhost because compose maps 5432 to
# 127.0.0.1:5432 on the host. The user/pass/db here MUST match the three
# variables above.
PG_DSN=postgresql://prism:prism@localhost:5432/prism_rag

# ─── Data directory on host ──────────────────────────────────────────────────
PRISM_DATA_DIR=/home/lisa/Arupreza/PRISM-RAG/data

# ─── Embedding (Phase 2) ─────────────────────────────────────────────────────
EMBED_DEVICE=cuda

# ─── vLLM OpenAI-compatible endpoint (Phase 3) ───────────────────────────────
SUMMARIZER_URL=http://localhost:8000/v1
SUMMARIZER_KEY=EMPTY